# ===============================
# Git Ignore do projeto TaNaLista
# ===============================

# -------------------------------
# BACK-END (Java / Spring Boot)
# -------------------------------

# Arquivos de classe compilados
*.class

# Pacotes compilados
*.jar
*.war
*.ear

# Pastas de build
target/
build/
bin/

# IDEs / Editor
.idea/
.settings/
.project
.classpath
.factorypath
*.iml
*.ipr
*.iws
.vscode/

# Arquivos de sistema e temporários
.DS_Store
Thumbs.db
*.log
*.tmp

# -------------------------------
# FRONT-END (Flutter)
# -------------------------------

# Pastas de build e cache do Flutter
build/
.dart_tool/
.packages
.pub-cache/
.pub/

# Plugins do Flutter
.flutter-plugins
.flutter-plugins-dependencies

# IDEs / Editor
.idea/
.vscode/

# Plataformas compiladas (não versionar, serão geradas a partir do código Dart)
# Geralmente android/ e ios/ gerados pelo Flutter não precisam subir no Git,
# pois são recompilados a partir do código Dart.
android/
ios/
macos/
linux/
windows/
web/

# Logs
*.log

# Outros arquivos gerados
*.iml
*.hprof
*.DS_Store
*.apk
*.ipa
*.keystore

# -------------------------------
# Comentário explicativo
# -------------------------------
# Este gitignore cobre tanto o back-end (Java/Spring Boot) quanto o front-end (Flutter),
# ignorando arquivos compilados, caches, IDEs, logs e plataformas geradas automaticamente.